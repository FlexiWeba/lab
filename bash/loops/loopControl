#!/bin/bash

dir="${1:?Usage: $0 <directory>}"

[[ -d "$dir" ]] || { echo "Not a directory: $dir" >&2; exit 1; }

for file in "$dir"/*; do
    [[ -f "$file" ]] || continue
    echo "Processing: $file"
done


# Process files, skip hidden ones
for file in * .*; do
    [[ "$file" == .* ]] && continue
    [[ -f "$file" ]] || continue
    echo "Processing: $file"
done

